APP_NAME=NewsFlow
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=America/Indiana/Indianapolis

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Gmail SMTP (use a Google "App Password", not your account password).
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

#-----------------------------------------------------------------------
# NewsFlow article sourcing
#-----------------------------------------------------------------------
# 'hybrid' (recommended) or 'stub' (offline placeholder feed, no keys needed).
NEWSPAPERFLOW_PROVIDER=hybrid
# Recommended source: THENEWSAPI (real-time, commercial) or NEWSDATA (free
# tier allows commercial use, 12h delay — fine for a 6 AM "yesterday" batch).
THENEWSAPI_KEY=
NEWSDATA_KEY=
GNEWS_KEY=
NEWSAPI_KEY=
# Optional LLM dedupe+summarizer (Claude Haiku) — leave blank to skip.
ANTHROPIC_API_KEY=
NEWSPAPERFLOW_LLM_MODEL=claude-haiku-4-5-20251001

#-----------------------------------------------------------------------
# Stripe / NewsFlow Pro (Laravel Cashier)
#-----------------------------------------------------------------------
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
CASHIER_CURRENCY=usd
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_PRO_LIFETIME=

#-----------------------------------------------------------------------
# Social sign-in (Socialite) — buttons only show when CLIENT_ID is set
#-----------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_REDIRECT_URI="${APP_URL}/auth/apple/callback"
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI="${APP_URL}/auth/discord/callback"

# --- Ads (Free tier; Pro removes them) -------------------------------------
# Web AdSense — leave blank for a dashed "Your Ad Here" placeholder in dev.
ADSENSE_CLIENT=
ADSENSE_USE_GOOGLE_CMP=false
ADSENSE_SLOT_MARKETING=
ADSENSE_SLOT_HOME_TOP=
ADSENSE_SLOT_HOME_MID=
ADSENSE_SLOT_PRICING_TOP=
ADSENSE_SLOT_WORLD_NEWS_TOP=
ADSENSE_SLOT_HOW_TO_USE_TOP=
ADSENSE_SLOT_FAQ_TOP=
ADSENSE_SLOT_ABOUT_TOP=
ADSENSE_SLOT_DASHBOARD_TOP=
ADSENSE_SLOT_DASHBOARD_BOTTOM=
ADSENSE_SLOT_SAVED_TOP=
ADSENSE_SLOT_SEARCH_TOP=
ADSENSE_SLOT_ARCHIVE_TOP=

# Mobile AdMob — app IDs are build-time; unit ID is served via /api/config.
ADMOB_APP_ID_ANDROID=
ADMOB_APP_ID_IOS=
ADMOB_UNIT_FEED_TAB=
