# ===== NewsroomFlow monorepo .gitignore =====
# Covers: Laravel/PHP (newsroom-flow-web), Node/Vite, and future Android/iOS apps.

# ---- Secrets & local data (NEVER commit) ----
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.jks
*.keystore
*.mobileprovision
keystore.properties
newsroom-flow-web/database/*.sqlite
newsroom-flow-web/database/*.sqlite-journal

# ---- Dependencies ----
node_modules/
# Composer deps only — anchored so it does NOT swallow published package view
# overrides like resources/views/vendor/mail (branded email templates).
newsroom-flow-web/vendor/
.pnp
.pnp.js

# ---- Claude Code local (personal, not shared) ----
.claude/settings.local.json
.claude/launch.json

# ---- OS / editor noise ----
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*~
.idea/
*.iml
.vscode/

# ---- Logs / caches ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.phpunit.result.cache
.phpunit.cache/

# ---- Laravel / PHP (newsroom-flow-web) ----
newsroom-flow-web/public/build/
newsroom-flow-web/public/hot
newsroom-flow-web/storage/*.key
newsroom-flow-web/storage/framework/cache/*
newsroom-flow-web/storage/framework/sessions/*
newsroom-flow-web/storage/framework/views/*
newsroom-flow-web/storage/framework/testing/*
newsroom-flow-web/storage/logs/*
newsroom-flow-web/bootstrap/cache/*.php
newsroom-flow-web/.phpunit.result.cache
newsroom-flow-web/auth.json

# ---- Node / Vite build output ----
dist-ssr/
*.local

# ---- Generated deliverables (regenerable documents — keep out of git) ----
/NewsroomFlow_Media_Kit.docx
/NewsroomFlow_Media_Kit.pdf

# ---- Android (future newsroom-flow-android) ----
newsroom-flow-android/.gradle/
newsroom-flow-android/.kotlin/
newsroom-flow-android/build/
newsroom-flow-android/**/build/
newsroom-flow-android/local.properties
newsroom-flow-android/.cxx/
newsroom-flow-android/captures/
*.apk
*.aab

# ---- Xcode / Swift (future newsroom-flow-ios) ----
DerivedData/
*.xcuserstate
xcuserdata/
.build/
Pods/
