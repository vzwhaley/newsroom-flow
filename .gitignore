# ===== NewsFlow monorepo .gitignore =====
# Covers: Laravel/PHP (newspaper-flow-web), Node/Vite, and future Android/iOS apps.

# ---- Secrets & local data (NEVER commit) ----
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.jks
*.keystore
*.mobileprovision
keystore.properties
newspaper-flow-web/database/*.sqlite
newspaper-flow-web/database/*.sqlite-journal

# ---- Dependencies ----
node_modules/
# Composer deps only — anchored so it does NOT swallow published package view
# overrides like resources/views/vendor/mail (branded email templates).
newspaper-flow-web/vendor/
.pnp
.pnp.js

# ---- Claude Code local (personal, not shared) ----
.claude/settings.local.json
.claude/launch.json

# ---- OS / editor noise ----
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*~
.idea/
*.iml
.vscode/

# ---- Logs / caches ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.phpunit.result.cache
.phpunit.cache/

# ---- Laravel / PHP (newspaper-flow-web) ----
newspaper-flow-web/public/build/
newspaper-flow-web/public/hot
newspaper-flow-web/storage/*.key
newspaper-flow-web/storage/framework/cache/*
newspaper-flow-web/storage/framework/sessions/*
newspaper-flow-web/storage/framework/views/*
newspaper-flow-web/storage/framework/testing/*
newspaper-flow-web/storage/logs/*
newspaper-flow-web/bootstrap/cache/*.php
newspaper-flow-web/.phpunit.result.cache
newspaper-flow-web/auth.json

# ---- Node / Vite build output ----
dist-ssr/
*.local

# ---- Generated deliverables (regenerable documents — keep out of git) ----
/NewsFlow_Media_Kit.docx
/NewsFlow_Media_Kit.pdf

# ---- Android (future newsflow-android) ----
newsflow-android/.gradle/
newsflow-android/.kotlin/
newsflow-android/build/
newsflow-android/**/build/
newsflow-android/local.properties
newsflow-android/.cxx/
newsflow-android/captures/
*.apk
*.aab

# ---- Xcode / Swift (future newsflow-ios) ----
DerivedData/
*.xcuserstate
xcuserdata/
.build/
Pods/
